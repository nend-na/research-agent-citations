# Which LLM provider to use for answer synthesis.
# Options: mock (no key needed, extractive fallback), anthropic, openai, groq
LLM_PROVIDER=mock

# Only needed if LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Only needed if LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Only needed if LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Retrieval configuration
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K=5

# Folders
UPLOAD_DIR=data/uploads
SAMPLE_DIR=data/sample_docs
